# Neon PostgreSQL connection string
DATABASE_URL=your_neon_database_url

# Session signing secret (generate with: openssl rand -base64 32)
AUTH_SECRET=your-secret-key-here

# App URL (for Google OAuth redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (for Continue with Google login — pet owners)
# Redirect URI in Google Cloud Console: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID= your_google_client_id
GOOGLE_CLIENT_SECRET= your_google_client_secret

# Google Gemini AI (for PawBot chatbot)
GEMINI_API_KEY=
